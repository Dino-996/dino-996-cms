{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "layout": {
      "type": "string",
      "default": "layouts/post.njk",
      "required": true
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "required": true,
      "unique": false
    },
    "description": {
      "type": "text",
      "minLength": 10,
      "required": true
    },
    "excerpt": {
      "type": "text",
      "minLength": 10,
      "required": false
    },
    "tags": {
      "type": "json",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "imageAlt": {
      "type": "string",
      "default": "Immagine generata con IA"
    }
  }
}
